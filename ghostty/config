theme = Banana Blueberry
font-size = 16
font-family = FiraCode Nerd Font Mono
window-save-state = always
font-thicken = true
cursor-style = block
cursor-color = #605D5D
cursor-text = #FDFDFD
window-height = 8
window-width = 8
macos-icon = retro
working-directory = inherit

quick-terminal-position = bottom
quick-terminal-size = 40%
quick-terminal-space-behavior = remain
keybind = global:cmd+option+control+shift+t=toggle_quick_terminal

